{
  "manifest_version": 3,
  "name": "ZamDB - Steam OSINT",
  "version": "1.0.0",
  "description": "Auditoria de DRM, Histórico de Preços e Banco de Dados Forense para Steam.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://store.steampowered.com/*",
    "*://api.gg.deals/*",
    "*://www.reddit.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16_gray.png",
      "32": "icons/icon32_gray.png",
      "128": "icons/icon128_gray.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://store.steampowered.com/app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}